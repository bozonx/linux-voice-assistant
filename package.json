  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.0.10",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.3.3",
    "typescript": "^5.8.3"
  }
