{
  "name": "librnet-assistant",
  "version": "0.0.3",
  "private": true,
  "description": "Librnet assistant built with Tauri and Vue",
  "scripts": {
    "dev:ui": "pnpm --filter ./apps/desktop-ui dev",
    "build:ui": "pnpm --filter ./apps/desktop-ui build",
    "type-check": "pnpm --filter ./apps/desktop-ui type-check",
    "tauri": "tauri",
