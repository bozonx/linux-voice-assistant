{
  "name": "librnet-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Librnet assistant built with Tauri and Vue",
  "scripts": {
    "dev:ui": "pnpm --env-file=.env --filter librnet-assistant-ui dev",
    "build:ui": "pnpm --filter librnet-assistant-ui build",
    "type-check": "pnpm --filter librnet-assistant-ui type-check",
    "tauri": "tauri",
    "tauri:dev": "pnpm --env-file=.env tauri dev --config \"{\\\"build\\\": {\\\"devUrl\\\": \\\"http://localhost:${PORT:-3000}\\\"}}\"",
    "tauri:build": "tauri build",
    "dev": "pnpm dev:ui",
    "build": "pnpm build:ui"
  },
  "author": "Kozyrin Ivan",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^6.0.3"
  }
}