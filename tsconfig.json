{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    // "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["packages/shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "apps", "_old", "src-tauri"]
}
