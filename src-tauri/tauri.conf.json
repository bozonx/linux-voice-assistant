{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Librnet Assistant",
  "version": "0.0.3",
  "identifier": "bozonx.desktop-assistant",
  "build": {
    "beforeDevCommand": "pnpm dev:ui",
    "beforeBuildCommand": "pnpm build:ui",
    "frontendDist": "../apps/desktop-ui/dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Librnet Assistant",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost http: https: ws: wss:",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": ["icons/icon.png"]
  }
}
