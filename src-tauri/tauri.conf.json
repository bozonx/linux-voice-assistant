{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TyCo - typing companion",
  "version": "0.0.3",
  "identifier": "com.tyco.app",
  "build": {
    "beforeDevCommand": "pnpm dev:ui",
    "beforeBuildCommand": "pnpm build:ui",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "TyCo - typing companion",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/models/whisper/**",
          "$APPDATA/models/llm/**"
        ]
      },
      "csp": {
        "default-src": "'self' asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost http: https: ws: wss:",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": ["icons/icon.png"]
  }
}
